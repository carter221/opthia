# =============================================================================
# Opthia - Environment Variables (TEMPLATE)
# =============================================================================
# Copier ce fichier en .env et remplir les valeurs.
#   cp .env.example .env
# =============================================================================

# --- MongoDB ---
MONGO_ROOT_USERNAME=opthia_admin
MONGO_ROOT_PASSWORD=
MONGO_DATABASE=ophtia

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=opthia_rmq
RABBITMQ_DEFAULT_PASS=

# --- PostgreSQL (Airflow) ---
POSTGRES_USER=airflow
POSTGRES_PASSWORD=
POSTGRES_DB=airflow

# --- Mongo Express ---
ME_CONFIG_BASICAUTH_USERNAME=opthia_me_admin
ME_CONFIG_BASICAUTH_PASSWORD=

# --- Airflow ---
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=admin@ophtia.local

# --- Traefik / Domain ---
OPTHIA_DOMAIN=ophtia.sjudicael.top
