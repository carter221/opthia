# =============================================================================
# Opthia - Environment Variables (TEMPLATE)
# =============================================================================
# Copier ce fichier en .env et remplir les valeurs.
#   cp .env.example .env
# =============================================================================

# --- MongoDB ---
MONGO_ROOT_USERNAME=opthia_admin
MONGO_ROOT_PASSWORD=your_secure_mongo_password
MONGO_DATABASE=ophtia

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=opthia_rmq
RABBITMQ_DEFAULT_PASS=your_secure_rabbitmq_password

# --- Mongo Express ---
ME_CONFIG_BASICAUTH_USERNAME=opthia_me_admin
ME_CONFIG_BASICAUTH_PASSWORD=your_secure_me_password

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Traefik / Domain ---
OPTHIA_DOMAIN=ophtia.sjudicael.top
