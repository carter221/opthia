plt.show()

# ==========================================
# 6. MOTEUR GRAD-CAM (THERMOMÈTRE INVERSÉ)
# ==========================================
class GradCAM:
    def __init__(self, model, target_layer):
        self.model = model
        self.target_layer = target_layer
        self.gradients = None
        self.activations = None
        self.target_layer.register_forward_hook(self.save_activation)
        self.target_layer.register_full_backward_hook(self.save_gradient)

    def save_activation(self, module, input, output):
        self.activations = output

    def save_gradient(self, module, grad_input, grad_output):
        self.gradients = grad_output[0] # Extraction sécurisée du tuple

    def generate_cam(self, input_tensor, pred_label):
        self.model.eval()
        output = self.model(input_tensor)
        self.model.zero_grad()
        
        logit = output.squeeze()
        if logit.dim() > 0:
            logit = logit.sum()
            
        if pred_label == 0.0:
            class_loss = -logit 
        else:
            class_loss = logit  
            
        class_loss.backward()

        pooled_gradients = torch.mean(self.gradients, dim=(2, 3), keepdim=True)
        activations = self.activations.detach()
        weighted_activations = activations * pooled_gradients
        
        heatmap = torch.sum(weighted_activations, dim=1).squeeze()
        heatmap = F.relu(heatmap)
        
        heatmap_max = torch.max(heatmap)
        if heatmap_max == 0:
            heatmap_max = 1e-8
        heatmap /= heatmap_max
        return heatmap.cpu().numpy()

def visualize_gradcam(model, image, pred_label, true_label, device):
    target_layer = model.features[-1] 
    grad_cam = GradCAM(model, target_layer)
    input_tensor = image.unsqueeze(0).to(device)
    
    heatmap = grad_cam.generate_cam(input_tensor, pred_label)
    
    img_display = image.cpu().numpy().transpose(1, 2, 0)
    img_display = img_display * np.array([0.229, 0.224, 0.225]) + np.array([0.485, 0.456, 0.406])
    img_display = np.clip(img_display, 0, 1)
    
    # Correction stricte des dimensions (Largeur, Hauteur) pour OpenCV
    heatmap_resized = cv2.resize(heatmap, (img_display.shape[1], img_display.shape[0]))
    heatmap_colored = cv2.applyColorMap(np.uint8(255 * heatmap_resized), cv2.COLORMAP_JET)
    heatmap_colored = cv2.cvtColor(heatmap_colored, cv2.COLOR_BGR2RGB) / 255.0
    
    superimposed = heatmap_colored * 0.4 + img_display * 0.6
    superimposed = np.clip(superimposed, 0, 1)
    
    fig, axes = plt.subplots(1, 3, figsize=(15, 5))
    
    axes[0].imshow(img_display)
    axes[0].set_title(f"Image originale\nVraie classe: {'Glaucome' if true_label==1.0 else 'Sain'}")
    axes[0].axis('off')
    
    axes[1].imshow(heatmap_resized, cmap='jet')
    axes[1].set_title(f"Grad-CAM Heatmap\nPrédiction IA: {'Glaucome' if pred_label==1.0 else 'Sain'}")
    axes[1].axis('off')
    
    axes[2].imshow(superimposed)
    axes[2].set_title("Superposition (Mode Ophtia)")
    axes[2].axis('off')
    
    plt.tight_layout()
    plt.show()

# ==========================================
# 7. EXÉCUTION DU TEST VISUEL
# ==========================================
print("\n👁️ Génération des tests visuels (Grad-CAM)...")
images, labels_batch, _ = next(iter(train_loader))
images, labels_batch = images.to(DEVICE), labels_batch.to(DEVICE)
outputs = model(images)
preds = (torch.sigmoid(outputs) > 0.5).float()

for i in range(min(3, len(images))):
    visualize_gradcam(model, images[i], preds[i].item(), labels_batch[i].item(), DEVICE)
