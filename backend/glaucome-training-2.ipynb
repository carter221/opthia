axs[1, 1].grid(True, alpha=0.3)

plt.tight_layout()
plt.show()

# 5.2 Matrice de confusion & Courbe ROC
cm = confusion_matrix(all_labels, all_preds)
fpr, tpr, _ = roc_curve(all_labels, all_probs)

fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 6))

sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', ax=ax1, xticklabels=['Normal (0)', 'Glaucome (1)'], yticklabels=['Normal (0)', 'Glaucome (1)'])
ax1.set_title('Matrice de Confusion - Test Set', fontsize=14, fontweight='bold')
