import os
import torch
import torch.nn as nn
import torch.optim as optim
import torchvision.transforms as transforms
import torchvision.models as models
from torch.optim.lr_scheduler import ReduceLROnPlateau
from torch.utils.data import Dataset, DataLoader, ConcatDataset, WeightedRandomSampler
import pandas as pd
import numpy as np
import cv2
import matplotlib.pyplot as plt
import seaborn as sns
from PIL import Image
from sklearn.metrics import accuracy_score, cohen_kappa_score, roc_auc_score, confusion_matrix, roc_curve
import torch.nn.functional as F

# ==========================================
# 1. CONFIGURATION ET CHEMINS
# ==========================================
DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"🚀 Appareil utilisé : {DEVICE}")

# ⚠️ CHEMINS À VÉRIFIER SELON VOTRE ENVIRONNEMENT KAGGLE
ODIR_CSV_PATH = '/kaggle/input/datasets/swatinandha/odir-5k/final_clean_dataset.csv'  
ODIR_IMG_DIR = '/kaggle/input/datasets/swatinandha/odir-5k/ben_graham_images-20260216T043422Z-3-001/ben_graham_images'

# Chemin mis à jour pour Drishti avec ses sous-dossiers
DRISHTI_IMG_DIR = '/kaggle/input/drishti-gs/Drishti-GS - RETINA DATASET FOR ONH SEGMENTATION' 

# ⚠️ Le chemin vers votre ANCIEN modèle multicouches pour le Fine-Tuning
OLD_MODEL_PATH = '/kaggle/input/VOTRE_DOSSIER_MODELE/best_efficientnet_glaucoma.pth' 

MODEL_SAVE_PATH = 'ophtia_glaucoma_odir_universel_finetuned.pth' 

EPOCHS = 20
BATCH_SIZE = 32

# ==========================================
# 2. PRÉPARATION DES DONNÉES ET DATASETS
# ==========================================
# Le RandomCrop (recadrage aléatoire) empêche l'IA de mémoriser les bordures
train_transform = transforms.Compose([
    transforms.Resize((256, 256)), 
    transforms.RandomCrop((224, 224)), # Anti-Shortcut Learning (Supprime les bordures noires)
    transforms.RandomHorizontalFlip(),
    transforms.RandomRotation(15),
    transforms.ColorJitter(brightness=0.2, contrast=0.2),
    transforms.ToTensor(),
    transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])
])

class ODIR_Glaucoma_Dataset(Dataset):
    def __init__(self, csv_file, img_dir, transform=None):
        self.data = pd.read_csv(csv_file)
        self.img_dir = img_dir
        self.transform = transform

    def __len__(self):
        return len(self.data)

    def __getitem__(self, idx):
        row = self.data.iloc[idx]
        img_name = os.path.join(self.img_dir, row['filename'])
        image = Image.open(img_name).convert('RGB')
        
        # ⚠️ CORRECTION : Le nom de colonne dans ODIR clean est 'G' pour Glaucome
        label = float(row['G']) 
        
        if self.transform:
            image = self.transform(image)
        return image, label, img_name

class Drishti_Glaucoma_Dataset(Dataset):
    def __init__(self, root_dir, transform=None):
        self.root_dir = root_dir
        self.transform = transform
        self.image_paths = []
        self.labels = []
        
        # os.walk fouille automatiquement dans Test et Training comme dans l'ancien modèle
        for subdir, _, files in os.walk(root_dir):
            for file in files:
                if file.lower().endswith(('.png', '.jpg', '.jpeg')) and 'mask' not in file.lower() and 'softmap' not in file.lower():
                    full_path = os.path.join(subdir, file)
                    self.image_paths.append(full_path)
                    
                    if 'glaucoma' in subdir.lower() or 'glau' in file.lower():
                        self.labels.append(1.0)
                    elif 'normal' in subdir.lower() or 'sain' in file.lower():
                        self.labels.append(0.0)
                    else:
                        self.labels.append(1.0) # Fallback sécurisé
                        
    def __len__(self):
        return len(self.image_paths)

    def __getitem__(self, idx):
        img_path = self.image_paths[idx]
        image = Image.open(img_path).convert('RGB')
        label = self.labels[idx]
        
        if self.transform:
            image = self.transform(image)
        return image, label, img_path

# Chargement et Fusion (Joint Training)
dataset_odir = ODIR_Glaucoma_Dataset(csv_file=ODIR_CSV_PATH, img_dir=ODIR_IMG_DIR, transform=train_transform)

if os.path.exists(DRISHTI_IMG_DIR):
    dataset_drishti = Drishti_Glaucoma_Dataset(root_dir=DRISHTI_IMG_DIR, transform=train_transform)
    if len(dataset_drishti) > 0:
        dataset_total = ConcatDataset([dataset_odir, dataset_drishti])
        print(f"📊 Datasets fusionnés : ODIR ({len(dataset_odir)}) + Drishti ({len(dataset_drishti)})")
    else:
        dataset_total = dataset_odir
else:
    dataset_total = dataset_odir
    print(f"📊 Dataset chargé : ODIR uniquement")

# --- CORRECTION : CALCUL DES POIDS POUR SURMONTER LE DÉSÉQUILIBRE DE CLASSE ---
def get_all_labels(dataset):
    if isinstance(dataset, ConcatDataset):
        labels = []
        for ds in dataset.datasets:
            labels.extend(get_all_labels(ds))
        return labels
    elif hasattr(dataset, 'labels'):
        return dataset.labels
    elif hasattr(dataset, 'data'):
        return dataset.data['G'].tolist()
    return []

all_labels = get_all_labels(dataset_total)
all_labels_np = np.array(all_labels, dtype=int)

class_counts = np.bincount(all_labels_np)
class_weights = 1.0 / np.where(class_counts == 0, 1, class_counts)
sample_weights = [class_weights[label] for label in all_labels_np]

sampler = WeightedRandomSampler(
    weights=sample_weights, 
    num_samples=len(sample_weights), 
    replacement=True
)

train_loader = DataLoader(dataset_total, batch_size=BATCH_SIZE, sampler=sampler, num_workers=2)

# ==========================================
# 3. LE MODÈLE (FINE-TUNING DE L'ANCIENNE ARCHITECTURE)
# ==========================================
model = models.efficientnet_b0(weights=None)

# Le paramètre in_features se trouve sur la couche linéaire à l'index 1.
in_features = model.classifier[1].in_features

# 1. On restaure l'architecture multicouches robuste du premier modèle
model.classifier = nn.Sequential(
    nn.Dropout(p=0.4), 
    nn.Linear(in_features, 512), 
    nn.BatchNorm1d(512), 
    nn.ReLU(inplace=True),
    nn.Dropout(p=0.3), 
    nn.Linear(512, 256), 
    nn.BatchNorm1d(256), 
    nn.ReLU(inplace=True),
    nn.Dropout(p=0.2), 
    nn.Linear(256, 1) # Sortie unique pour la production
)

# 2. Transfer Learning (Chargement des anciens poids)
if os.path.isfile(OLD_MODEL_PATH):
    print(f"📥 Chargement de l'ancien modèle pour Fine-Tuning...")
    # ⚠️ CORRECTION PYTORCH 2.6 : weights_only=False ajouté pour autoriser le désarchivage
    state_dict = torch.load(OLD_MODEL_PATH, map_location=DEVICE, weights_only=False)
    model.load_state_dict(state_dict.get('model_state_dict', state_dict), strict=False)
    print("✅ Transfer Learning prêt !")
else:
    print(f"⚠️ Ancien modèle introuvable. Entraînement depuis le début.")

model = model.to(DEVICE)

# Configuration calquée sur votre PDF d'origine
criterion = nn.BCEWithLogitsLoss()
# ⚠️ Learning Rate ajusté à 5e-5 pour donner plus de flexibilité lors de la convergence équitable
optimizer = optim.AdamW(model.parameters(), lr=5e-5, weight_decay=1e-4)
scheduler = ReduceLROnPlateau(optimizer, mode='min', factor=0.5, patience=3, verbose=True, min_lr=1e-7)

# Early Stopping
class EarlyStopping:
    def __init__(self, patience=5):
        self.patience = patience
        self.counter = 0
        self.best_loss = None
        self.early_stop = False

    def __call__(self, val_loss, model, path):
        if self.best_loss is None:
            self.best_loss = val_loss
            torch.save(model.state_dict(), path)
        elif val_loss > self.best_loss:
            self.counter += 1
            if self.counter >= self.patience:
                self.early_stop = True
        else:
            self.best_loss = val_loss
            torch.save(model.state_dict(), path)
            self.counter = 0

early_stopping = EarlyStopping(patience=5)

# ==========================================
# 4. BOUCLE D'ENTRAÎNEMENT & MÉTRIQUES
# ==========================================
print(f"\n🚀 Lancement de l'entraînement... Sauvegarde sous : {MODEL_SAVE_PATH}")

history = {'loss': [], 'acc': [], 'kappa': [], 'auc': [], 'lr': []}

for epoch in range(EPOCHS):
    model.train()
    running_loss = 0.0
    all_preds, all_labels, all_probs = [], [], []
    
    for images, labels_batch, _ in train_loader:
        images = images.to(DEVICE)
        labels_batch = labels_batch.unsqueeze(1).float().to(DEVICE)
        
        optimizer.zero_grad()
        outputs = model(images)
        loss = criterion(outputs, labels_batch)
        loss.backward()
        optimizer.step()
        
        running_loss += loss.item()
        
        probs = torch.sigmoid(outputs).detach().cpu().numpy()
        preds = (probs > 0.5).astype(float)
        
        all_probs.extend(probs)
        all_preds.extend(preds)
        all_labels.extend(labels_batch.cpu().numpy())
        
    epoch_loss = running_loss / len(train_loader)
    epoch_acc = accuracy_score(all_labels, all_preds)
    epoch_kappa = cohen_kappa_score(all_labels, all_preds)
    
    try:
        epoch_auc = roc_auc_score(all_labels, all_probs)
    except ValueError:
        epoch_auc = 0.5
        
    current_lr = optimizer.param_groups[0]['lr']
    
    history['loss'].append(epoch_loss)
    history['acc'].append(epoch_acc)
    history['kappa'].append(epoch_kappa)
    history['auc'].append(epoch_auc)
    history['lr'].append(current_lr)
    
    scheduler.step(epoch_loss)
    early_stopping(epoch_loss, model, MODEL_SAVE_PATH)
    
    print(f"Epoch [{epoch+1}/{EPOCHS}] - Loss: {epoch_loss:.4f} - Acc: {epoch_acc:.4f} - Kappa: {epoch_kappa:.4f} - AUC: {epoch_auc:.4f}")
    
    if early_stopping.early_stop:
        print("🛑 Early stopping déclenché !")
        break

# ==========================================
# 5. GRAPHIQUES ET RÉSULTATS
# ==========================================
print("\n📊 Génération des graphiques...")
model.load_state_dict(torch.load(MODEL_SAVE_PATH, map_location=DEVICE))
model.eval()

# 5.1 Courbes d'apprentissage
fig, axs = plt.subplots(2, 2, figsize=(15, 10))
fig.suptitle("Courbes d'apprentissage - Modèle Glaucome Universel", fontsize=16)

